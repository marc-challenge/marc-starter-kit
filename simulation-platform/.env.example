# MARC 2026 - participant platform run parameters. `cp simulation-platform/.env.example simulation-platform/.env` then edit.
# (compose auto-loads it. If unset, the defaults below are used.)

# Run scenario (public practice scenarios: marc2026_demo | marc2026_chungmu)
#   marc2026_demo = baseline walkthrough scenario (default); marc2026_chungmu = full self-scoring practice set.
ENV_MARC_SCENARIO=marc2026_demo

# Headless or not. Default false = view the GUI score panel/viewport (run `xhost +local:root` on the host first).
# Set true for a headless server with no display.
HEADLESS=false

# ROS2 DDS domain - must match the participant app (separate machine) for communication
ROS_DOMAIN_ID=0

# Auto-start. Problem selection is automatic: ./problems.yaml (mounted) is used when present —
# pose only its enabled items; delete it to pose all problems. Edit by hand or regenerate with
# `bash simulation-platform/marc.sh select <scenario>`. No env var needed to activate it.
MARC_AUTO_START=1
# These apply only when problems.yaml is absent/invalid (STAGE1=all|first|"<id>,<id>" / STAGE2=off|auto|"<id>").
MARC_AUTO_STAGE1=all
MARC_AUTO_STAGE2=auto
